// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  SKK
  UDBO
  UBUIO
  TREASURY
  UIT
}

model Customer {
  customer_id Int    @id
  address     String
  private_key String

  first_name      String?
  middle_name     String?
  last_name       String?
  phone           String?
  email           String?
  status_comment  String?
  push_enabled    Boolean           @default(true)
  tariff_category TariffCategory    @default(K1)
  residency       CustomerResidency @default(RESIDENT)
  status          UserStatus        @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // last login metadata
  last_login_at     DateTime?
  last_login_ip     String?
  last_login_device String?

  balances                        UserAssetBalance[]
  withdrawals                     WithdrawRequest[]
  payment_operations              PaymentOperation[] @relation("payment_operation_customer")
  counterparty_payment_operations PaymentOperation[] @relation("payment_operation_counterparty")
  ledger_entries                  LedgerEntry[]
  support_messages                SupportMessage[]
  support_tickets                 SupportTicket[]
  push_tokens                     UserPushToken[]

  sender_transactions   Transaction[] @relation("tx_sender")
  receiver_transactions Transaction[] @relation("tx_receiver")

  @@map("customers")
}

enum TariffCategory {
  K1
  K2
  K3
  K4
  K5
  K6
}

enum CustomerResidency {
  RESIDENT
  NON_RESIDENT
}

enum SupportMessageRole {
  USER
  ASSISTANT
  ADMIN
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum PushPlatform {
  ANDROID
  IOS
}

enum Asset {
  ESOM
  SOM
  BTC
  ETH
  USDT_TRC20
}

enum WithdrawStatus {
  PENDING
  SUBMITTED
  SUCCESS
  FAILED
}

enum PaymentOperationType {
  DEPOSIT
  INTERNAL_TRANSFER
  WITHDRAW
  SWEEP
  COMPENSATION
}

enum PaymentOperationStatus {
  NEW
  RESERVED
  DB_COMMITTED
  BROADCASTED
  CONFIRMED
  FAILED
  COMPENSATED
}

enum Network {
  TRON
}

enum OperationInitiatorType {
  USER
  SYSTEM
  WEBHOOK
}

enum OperationAddressKind {
  TREASURY
  USER_WALLET
  EXTERNAL
  INTERNAL_LEDGER
}

enum BlockchainTransactionDirection {
  INBOUND
  OUTBOUND
}

enum BlockchainTransactionStatus {
  CREATED
  BROADCASTED
  CONFIRMED
  FAILED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
  COMPENSATION
}

enum LedgerAccountType {
  USER_AVAILABLE
}

enum LedgerEntryStatus {
  POSTED
}

enum TransactionKind {
  BANK_TO_BANK
  BANK_TO_WALLET
  WALLET_TO_BANK
  WALLET_TO_WALLET
  CONVERSION
  WITHDRAW_CRYPTO
}

enum TransactionStatus {
  PENDING
  SUCCESS
  REJECTED
  FAILED
}

enum TariffOperation {
  SOM_TO_ESOM
  ESOM_TO_SOM
  ESOM_TO_BTC
  ESOM_TO_USDT_TRC20
  ESOM_TO_ETH
  BTC_TO_ETH
  BTC_TO_USDT_TRC20
  USDT_TRC20_TO_ETH
  USDT_TRC20_TO_ESOM
  WALLET_TRANSFER_ESOM
  WALLET_TRANSFER_BTC
  WALLET_TRANSFER_ETH
  WALLET_TRANSFER_USDT_TRC20
}

enum AntiFraudRuleKey {
  FIAT_ANY_GE_1M
  ONE_TIME_GE_8M
  FREQUENT_OPS_3_30D_EACH_GE_100K
  WITHDRAW_AFTER_LARGE_INFLOW
  SPLITTING_TOTAL_14D_GE_1M
  THIRD_PARTY_DEPOSITS_3_30D_TOTAL_GE_1M
  AFTER_INACTIVITY_6M
  MANY_SENDERS_TO_ONE_10_PER_MONTH
}

enum AntiFraudCaseStatus {
  OPEN
  APPROVED
  REJECTED
}

model AntiFraudRule {
  id                Int              @id @default(autoincrement())
  key               AntiFraudRuleKey @unique
  enabled           Boolean          @default(true)
  period_days       Int?
  threshold_som     Decimal?         @db.Decimal(38, 18)
  min_count         Int?
  percent_threshold Decimal?         @db.Decimal(5, 2)
  updatedAt         DateTime         @updatedAt

  @@map("antifraud_rules")
}

model AntiFraudCase {
  id             Int                 @id @default(autoincrement())
  transaction_id Int                 @unique
  rule_key       AntiFraudRuleKey
  status         AntiFraudCaseStatus @default(OPEN)
  reason         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@map("antifraud_cases")
}

model Settings {
  id                          Int     @id @default(1)
  esom_per_usd                Decimal @db.Decimal(38, 18)
  esom_som_conversion_fee_pct Decimal @db.Decimal(5, 2)
  esom_som_conversion_fee_min Decimal @default(0) @db.Decimal(38, 18)

  btc_trade_fee_pct  Decimal @db.Decimal(5, 2)
  eth_trade_fee_pct  Decimal @db.Decimal(5, 2)
  usdt_trade_fee_pct Decimal @db.Decimal(5, 2)

  btc_withdraw_fee_fixed  Decimal @db.Decimal(38, 18)
  eth_withdraw_fee_fixed  Decimal @db.Decimal(38, 18)
  usdt_withdraw_fee_fixed Decimal @db.Decimal(38, 18)

  min_withdraw_btc        Decimal @db.Decimal(38, 18)
  min_withdraw_eth        Decimal @db.Decimal(38, 18)
  min_withdraw_usdt_trc20 Decimal @db.Decimal(38, 18)

  updatedAt DateTime @updatedAt

  @@map("settings")
}

model TariffSetting {
  id          Int               @id @default(autoincrement())
  category    TariffCategory
  residency   CustomerResidency
  operation   TariffOperation
  percent_fee Decimal           @default(0) @db.Decimal(5, 2)
  fixed_fee   Decimal           @default(0) @db.Decimal(38, 18)
  updatedAt   DateTime          @updatedAt

  @@unique([category, residency, operation])
  @@map("tariff_settings")
}

model UserAssetBalance {
  id          Int      @id @default(autoincrement())
  customer_id Int
  asset       Asset
  balance     Decimal  @default(0) @db.Decimal(38, 18)
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customer_id], references: [customer_id])

  @@unique([customer_id, asset])
  @@map("user_asset_balances")
}

model Transaction {
  id     Int               @id @default(autoincrement())
  kind   TransactionKind
  status TransactionStatus @default(PENDING)

  amount_in  Decimal @db.Decimal(38, 18)
  asset_in   Asset
  amount_out Decimal @db.Decimal(38, 18)
  asset_out  Asset

  fee_amount   Decimal? @db.Decimal(38, 18) // optional fee in same asset units
  price_usd    Decimal? @db.Decimal(38, 18) // unit price in USD when applicable
  notional_usd Decimal? @db.Decimal(38, 18) // optional notional in USD for conversions/trades

  tx_hash    String?
  bank_op_id Int?

  sender_customer_id      Int?
  receiver_customer_id    Int?
  sender_wallet_address   String?
  receiver_wallet_address String?
  external_address        String?

  comment   String?
  createdAt DateTime @default(now())

  sender_customer   Customer?      @relation("tx_sender", fields: [sender_customer_id], references: [customer_id])
  receiver_customer Customer?      @relation("tx_receiver", fields: [receiver_customer_id], references: [customer_id])
  anti_fraud_case   AntiFraudCase?
  ledger_entries    LedgerEntry[]
  accounting_postings AccountingPosting[]

  @@index([kind])
  @@index([status])
  @@index([createdAt])
  @@index([sender_customer_id])
  @@index([receiver_customer_id])
  @@map("transactions")
}

model WithdrawRequest {
  id          Int            @id @default(autoincrement())
  customer_id Int
  asset       Asset
  address     String
  amount      Decimal        @db.Decimal(38, 18)
  fee         Decimal        @db.Decimal(38, 18)
  txid        String?
  status      WithdrawStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  customer Customer @relation(fields: [customer_id], references: [customer_id])

  @@map("withdraw_requests")
}

model PaymentOperation {
  id                       Int                    @id @default(autoincrement())
  operation_type           PaymentOperationType
  status                   PaymentOperationStatus @default(NEW)
  idempotency_key          String                 @unique
  customer_id              Int
  counterparty_customer_id Int?
  network                  Network                @default(TRON)
  from_address             String
  to_address               String
  source_kind              OperationAddressKind?
  destination_kind         OperationAddressKind?
  asset                    Asset
  amount                   Decimal                @db.Decimal(38, 18)
  amount_raw               String                 @default("0")
  decimals                 Int                    @default(6)
  tx_hash                  String?                @unique
  attempt_count            Int                    @default(0)
  initiator_type           OperationInitiatorType @default(SYSTEM)
  last_error_code          String?
  last_error_message       String?
  payload                  Json?
  webhook_received_at      DateTime?
  broadcasted_at           DateTime?
  confirmed_at             DateTime?
  failed_at                DateTime?
  last_reconciled_at       DateTime?
  reversal_of_id           Int?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  customer                Customer                @relation("payment_operation_customer", fields: [customer_id], references: [customer_id])
  counterparty_customer   Customer?               @relation("payment_operation_counterparty", fields: [counterparty_customer_id], references: [customer_id])
  reversal_of             PaymentOperation?       @relation("payment_operation_reversal", fields: [reversal_of_id], references: [id])
  reversals               PaymentOperation[]      @relation("payment_operation_reversal")
  blockchain_transactions BlockchainTransaction[]
  ledger_entries          LedgerEntry[]
  accounting_postings     AccountingPosting[]

  @@index([customer_id, status])
  @@index([operation_type, status])
  @@index([network, tx_hash])
  @@map("payment_operations")
}

model BlockchainTransaction {
  id                   Int                            @id @default(autoincrement())
  payment_operation_id Int
  direction            BlockchainTransactionDirection
  network              Network                        @default(TRON)
  asset                Asset
  token_contract       String?
  tx_hash              String?
  from_address         String
  to_address           String
  amount               Decimal                        @db.Decimal(38, 18)
  amount_raw           String
  decimals             Int                            @default(6)
  status               BlockchainTransactionStatus    @default(CREATED)
  block_number         Int?
  block_timestamp      DateTime?
  confirmations        Int                            @default(0)
  gas_payer_address    String?
  fee_amount_raw       String?
  fee_asset            String?
  energy_used          Int?
  bandwidth_used       Int?
  receipt_status       String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  payment_operation PaymentOperation @relation(fields: [payment_operation_id], references: [id])
  ledger_entries    LedgerEntry[]

  @@unique([network, tx_hash])
  @@index([payment_operation_id, status])
  @@map("blockchain_transactions")
}

model LedgerEntry {
  id                        Int               @id @default(autoincrement())
  payment_operation_id      Int
  blockchain_transaction_id Int?
  transaction_id            Int?
  customer_id               Int
  asset                     Asset
  entry_type                LedgerEntryType
  account_type              LedgerAccountType
  amount                    Decimal           @db.Decimal(38, 18)
  amount_raw                String
  balance_before            Decimal?          @db.Decimal(38, 18)
  balance_after             Decimal?          @db.Decimal(38, 18)
  status                    LedgerEntryStatus @default(POSTED)
  reference_entry_id        Int?
  metadata                  Json?
  createdAt                 DateTime          @default(now())

  payment_operation      PaymentOperation       @relation(fields: [payment_operation_id], references: [id])
  blockchain_transaction BlockchainTransaction? @relation(fields: [blockchain_transaction_id], references: [id])
  transaction            Transaction?           @relation(fields: [transaction_id], references: [id])
  customer               Customer               @relation(fields: [customer_id], references: [customer_id])
  reference_entry        LedgerEntry?           @relation("ledger_entry_reference", fields: [reference_entry_id], references: [id])
  referenced_entries     LedgerEntry[]          @relation("ledger_entry_reference")

  @@index([payment_operation_id, status])
  @@index([customer_id, asset, createdAt])
  @@map("ledger_entries")
}

model AccountingPosting {
  id                   Int      @id @default(autoincrement())
  posting_group_key    String
  sequence             Int
  transaction_id       Int?
  payment_operation_id Int?
  debit_account_no     String
  debit_account_name   String
  credit_account_no    String
  credit_account_name  String
  asset                Asset
  amount               Decimal  @db.Decimal(38, 18)
  comment              String?
  metadata             Json?
  createdAt            DateTime @default(now())

  transaction        Transaction?      @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  payment_operation  PaymentOperation? @relation(fields: [payment_operation_id], references: [id], onDelete: SetNull)

  @@index([posting_group_key])
  @@index([transaction_id])
  @@index([payment_operation_id])
  @@map("accounting_postings")
}

model Admin {
  id                     Int              @id @default(autoincrement())
  email                  String           @unique
  password_hash          String
  first_name             String
  last_name              String
  role                   AdminRole        @default(SUPER_ADMIN)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  logs                   AdminActionLog[]
  closed_support_tickets SupportTicket[]  @relation("support_ticket_closed_by_admin")

  @@map("admins")
}

model Notification {
  id        Int      @id @default(autoincrement()) @map("notification_id")
  title     String   @db.VarChar(256)
  text      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
}

model SupportMessage {
  id          Int                @id @default(autoincrement()) @map("support_message_id")
  customer_id Int
  ticket_id   Int
  role        SupportMessageRole
  text        String
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  customer Customer      @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  ticket   SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([customer_id, createdAt])
  @@index([ticket_id, createdAt])
  @@map("support_messages")
}

model SupportTicket {
  id                 Int                 @id @default(autoincrement()) @map("support_ticket_id")
  customer_id        Int
  status             SupportTicketStatus @default(OPEN)
  closed_by_admin_id Int?
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  closedAt           DateTime?           @map("closed_at") @db.Timestamptz(6)
  lastMessageAt      DateTime            @default(now()) @map("last_message_at") @db.Timestamptz(6)

  customer        Customer         @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
  closed_by_admin Admin?           @relation("support_ticket_closed_by_admin", fields: [closed_by_admin_id], references: [id], onDelete: SetNull)
  messages        SupportMessage[]

  @@index([customer_id, status])
  @@index([status, lastMessageAt])
  @@map("support_tickets")
}

model UserPushToken {
  id          Int          @id @default(autoincrement())
  customer_id Int
  token       String       @unique
  platform    PushPlatform
  is_active   Boolean      @default(true)
  last_error  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@index([customer_id, is_active])
  @@map("user_push_tokens")
}

model AdminActionLog {
  id        Int      @id @default(autoincrement())
  admin_id  Int
  ip        String
  action    String
  details   String?
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [admin_id], references: [id])

  @@index([admin_id, createdAt])
  @@index([createdAt])
  @@map("admin_action_logs")
}

enum UserStatus {
  ACTIVE
  FRAUD
  BLOCKED
}
